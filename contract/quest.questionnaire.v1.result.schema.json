{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quest.questionnaire.v1.result",
  "title": "Quest Questionnaire Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "schema",
    "request_id",
    "nonce",
    "status",
    "questionnaire",
    "stage",
    "answers"
  ],
  "properties": {
    "protocol_version": {
      "const": "quest.questionnaire.v1"
    },
    "schema": {
      "const": "quest.questionnaire.v1.result"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "nonce": {
      "type": "string",
      "minLength": 16
    },
    "status": {
      "type": "string",
      "enum": ["completed", "cancelled", "error"]
    },
    "questionnaire": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 }
      }
    },
    "stage": {
      "type": "string"
    },
    "condition_number": {
      "type": ["integer", "null"]
    },
    "screen_sequence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "answers": {
      "type": "object"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "submitted_at", "duration_ms", "screens"],
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "submitted_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "screens": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "screen_id",
              "ordinal",
              "entered_at",
              "entered_elapsed_ms",
              "first_interaction_at",
              "first_interaction_elapsed_ms",
              "left_at",
              "left_elapsed_ms",
              "duration_ms",
              "interaction_count",
              "validation_failures"
            ],
            "properties": {
              "screen_id": {
                "type": "string"
              },
              "ordinal": {
                "type": "integer",
                "minimum": 0
              },
              "entered_at": {
                "type": "string",
                "format": "date-time"
              },
              "entered_elapsed_ms": {
                "type": "integer",
                "minimum": 0
              },
              "first_interaction_at": {
                "type": ["string", "null"],
                "format": "date-time"
              },
              "first_interaction_elapsed_ms": {
                "type": ["integer", "null"],
                "minimum": 0
              },
              "left_at": {
                "type": "string",
                "format": "date-time"
              },
              "left_elapsed_ms": {
                "type": "integer",
                "minimum": 0
              },
              "duration_ms": {
                "type": "integer",
                "minimum": 0
              },
              "interaction_count": {
                "type": "integer",
                "minimum": 0
              },
              "validation_failures": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "terminal": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["reason", "current_stage", "screen_index"],
      "properties": {
        "reason": { "type": "string" },
        "current_stage": { "type": "string" },
        "screen_index": { "type": "integer", "minimum": 0 }
      }
    },
    "error": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
