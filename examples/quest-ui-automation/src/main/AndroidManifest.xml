<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <application
        android:allowBackup="false"
        android:label="Quest UI Automation">
        <activity
            android:name=".ProjectionPromptActivity"
            android:exported="true"
            android:label="Projection Prompt Probe" />
        <activity
            android:name=".ProjectionRecordingActivity"
            android:exported="true"
            android:label="Projection Recording Probe" />
        <service
            android:name=".ProjectionRecordingService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />
    </application>
</manifest>
